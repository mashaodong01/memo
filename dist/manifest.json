{
  "manifest_version": 3,
  "name": "备忘录 & 任务管理",
  "version": "1.0.0",
  "description": "轻量级的备忘录和任务管理 Chrome 扩展",
  "permissions": ["storage", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "打开备忘录"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
